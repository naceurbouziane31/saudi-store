# =============================================================================
# Al Nadara — Backend env
# Copy to .env for local dev. In EasyPanel set each value via the Service UI.
# =============================================================================

# Environment mode: development | staging | production | test
APP_ENV=production
# Enables /docs, /openapi.json. Always false in production.
DEBUG=false

# ---- Database ---------------------------------------------------------------
# Accepts the raw EasyPanel-style URL (postgres://...?sslmode=disable);
# config.py normalizes it to postgresql+asyncpg://...
DATABASE_URL=postgres://alnadara:alnadara@alnadara_database:5432/alnadara?sslmode=disable

# ---- App secrets ------------------------------------------------------------
# Used for signing / hashing where needed. Generate a long random string.
SECRET_KEY=
# Protects /internal/* endpoints (must be sent as header X-Internal-Key).
INTERNAL_API_KEY=

# ---- HTTP / CORS ------------------------------------------------------------
# Comma-separated list of allowed origins for CORS preflight on /v1/*.
ALLOWED_ORIGINS=https://alnadara.shop

# ---- COD Network (fulfillment) ----------------------------------------------
# Base URL — usually https://api.codnetwork.com (confirm with their dashboard)
CODNETWORK_API_BASE=https://api.codnetwork.com
# API token — COD Network seller dashboard → My Profile → API Developer
# Set to "mock" in dev to use the in-process fake adapter.
CODNETWORK_API_KEY=
# Optional brand/outlet id (some accounts require it)
CODNETWORK_BRAND_ID=
# "lead" (default — call-center confirms) | "order" (ship immediately)
CODNETWORK_MODE=lead
# Shared secret COD Network signs incoming webhooks with (HMAC SHA-256).
CODNETWORK_WEBHOOK_SECRET=

# ---- Meta Conversions API ---------------------------------------------------
# Pixel ID — same value as NEXT_PUBLIC_META_PIXEL_ID
META_PIXEL_ID=
# CAPI access token — Events Manager → your pixel → Settings → CAPI
META_CAPI_ACCESS_TOKEN=
# Optional test event code — Events Manager → Test Events tab
META_TEST_EVENT_CODE=

# ---- TikTok Events API ------------------------------------------------------
TIKTOK_PIXEL_ID=
TIKTOK_CAPI_ACCESS_TOKEN=

# ---- Snap CAPI --------------------------------------------------------------
SNAP_PIXEL_ID=
SNAP_CAPI_ACCESS_TOKEN=

# ---- Google Sheets webhook (orders mirror) ----------------------------------
# Apps Script deployment URL (Deploy → New deployment → Web app → "Anyone")
SHEETS_WEBHOOK_URL=
# Shared secret matching the Apps Script property WEBHOOK_SECRET
SHEETS_WEBHOOK_SECRET=

# ---- Notifications ----------------------------------------------------------
# WhatsApp support number (E.164)
WHATSAPP_SUPPORT_NUMBER=+96550001234
SUPPORT_EMAIL=support@alnadara.shop
