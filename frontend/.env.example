# =============================================================================
# Al Nadara — Frontend env
# Copy to .env.local for local dev. In EasyPanel, set each value in the UI.
# =============================================================================

# ---- Public (NEXT_PUBLIC_*) — exposed to browser bundle ---------------------

# Canonical site URL (used for canonical tags, OG, sitemap, robots).
NEXT_PUBLIC_SITE_URL=https://alnadara.shop

# Public base URL of the FastAPI backend. The browser only hits Next.js
# route handlers, but this value is still embedded for canonical links + OG.
NEXT_PUBLIC_API_BASE_URL=https://api.alnadara.shop

# --- Pixel IDs (safe to expose, public by nature) ---
# Meta Pixel ID — Meta Events Manager → Data Sources → your pixel → "Pixel ID"
NEXT_PUBLIC_META_PIXEL_ID=
# TikTok Pixel ID — TikTok Events Manager → web events → Pixel ID
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
# Snap Pixel ID — Snap Ads Manager → Events Manager → Pixel ID
NEXT_PUBLIC_SNAP_PIXEL_ID=

# WhatsApp number for the floating CTA (E.164, e.g. +96550001234)
NEXT_PUBLIC_WHATSAPP_NUMBER=+96550001234
# Support inbox shown on contact + footer
NEXT_PUBLIC_SUPPORT_EMAIL=support@alnadara.shop

# ---- Server-only (NOT exposed to browser) -----------------------------------

# Internal URL the Next.js server uses to call FastAPI inside the docker network.
# In EasyPanel this is the in-cluster service hostname, e.g. http://backend:8000.
BACKEND_INTERNAL_URL=http://backend:8000

# Server-side CAPI access tokens — used by the /api/capi route handler when it
# forwards events to each platform. Never exposed to browser.
# Meta Conversions API token — Events Manager → your pixel → Settings → CAPI
META_CAPI_ACCESS_TOKEN=
# Optional Meta test event code — Events Manager → Test Events tab
META_TEST_EVENT_CODE=
# TikTok Events API access token — Events Manager → Settings → Events API
TIKTOK_CAPI_ACCESS_TOKEN=
# Snap CAPI access token — Snap Ads Manager → Business Settings → Conversions API
SNAP_CAPI_ACCESS_TOKEN=

# Node env (production for built images, development for local dev)
NODE_ENV=production
